{
  "manifest_version": 3,
  "name": "TrustGuard",
  "version": "1.0.0",
  "description": "Verify seller trustworthiness on Jiji and Facebook Marketplace",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": { "48": "icons/icon-48.png" }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.jiji.co.ke/*",
        "*://*.facebook.com/marketplace*"
      ],
      "js": ["content/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://*.jiji.co.ke/*",
    "*://*.facebook.com/*",
    "http://localhost:5000/*"
  ],
  "permissions": ["storage"]
}
